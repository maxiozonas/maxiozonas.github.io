---
import "../styles/global.css";
import type { Locale } from "../data/content";
import { profile } from "../data/content";

interface Props {
  locale: Locale;
  title?: string;
}

const { locale, title } = Astro.props;
const desc =
  locale === "es"
    ? "Portfolio de Máximo Ozonas — Líder de Desarrollo y Full Stack Developer. Laravel, React, Next.js, TypeScript, Docker."
    : "Máximo Ozonas portfolio — Development Lead & Full Stack Developer. Laravel, React, Next.js, TypeScript, Docker.";
const pageTitle = title ?? `${profile.name} — ${locale === "es" ? profile.roleEs : profile.roleEn}`;
const otherLocale = locale === "es" ? "en" : "es";
---

<!doctype html>
<html lang={locale}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={desc} />
    <meta name="author" content={profile.name} />
    <link rel="canonical" href={`https://maxiozonas.github.io/${locale}/`} />
    <link rel="alternate" hreflang={locale} href={`https://maxiozonas.github.io/${locale}/`} />
    <link rel="alternate" hreflang={otherLocale} href={`https://maxiozonas.github.io/${otherLocale}/`} />
    <link rel="alternate" hreflang="x-default" href="https://maxiozonas.github.io/" />

    <meta property="og:type" content="profile" />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={desc} />
    <meta property="og:url" content={`https://maxiozonas.github.io/${locale}/`} />
    <meta name="twitter:card" content="summary" />

    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='22' fill='%230a0e13'/%3E%3Ctext x='50' y='70' font-size='62' text-anchor='middle' fill='%23e0785f' font-family='monospace'%3E%E2%9C%B1%3C/text%3E%3C/svg%3E"
    />

    <script is:inline>
      (function () {
        document.documentElement.classList.add("js");
        try {
          var t = localStorage.getItem("theme");
          if (t !== "light" && t !== "dark") t = "dark";
          document.documentElement.setAttribute("data-theme", t);
        } catch (e) {
          document.documentElement.setAttribute("data-theme", "dark");
        }
      })();
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>
